{% comment %}
  PES Engine — Spec Sheet Button Block
  Shopify Theme Extension Block
  Injects "Download Spec Sheet" button on product pages

  Required metafields:
    - specs.datasheet_url (url)
    - specs.manual_url (url)
    - specs.warranty_url (url)
{% endcomment %}

{% assign datasheet_url = product.metafields.specs.datasheet_url %}
{% assign manual_url = product.metafields.specs.manual_url %}
{% assign warranty_url = product.metafields.specs.warranty_url %}
{% assign specs_json = product.metafields.specs.sheets_json %}

{% if datasheet_url != blank or manual_url != blank or warranty_url != blank or specs_json != blank %}
  <div class="pes-specs-wrapper">
    <h3 class="pes-specs-title">Technical Documentation</h3>

    <div class="pes-specs-buttons">
      {% if datasheet_url != blank %}
        <a href="{{ datasheet_url }}" class="pes-spec-button pes-spec-datasheet" target="_blank" rel="noopener noreferrer">
          <span class="pes-spec-icon">📄</span>
          <span class="pes-spec-label">Data Sheet</span>
          <span class="pes-spec-hint">PDF</span>
        </a>
      {% endif %}

      {% if manual_url != blank %}
        <a href="{{ manual_url }}" class="pes-spec-button pes-spec-manual" target="_blank" rel="noopener noreferrer">
          <span class="pes-spec-icon">📖</span>
          <span class="pes-spec-label">Installation Manual</span>
          <span class="pes-spec-hint">PDF</span>
        </a>
      {% endif %}

      {% if warranty_url != blank %}
        <a href="{{ warranty_url }}" class="pes-spec-button pes-spec-warranty" target="_blank" rel="noopener noreferrer">
          <span class="pes-spec-icon">🛡️</span>
          <span class="pes-spec-label">Warranty</span>
          <span class="pes-spec-hint">PDF</span>
        </a>
      {% endif %}

      {% if specs_json != blank %}
        {% for spec in specs_json %}
          <a href="{{ spec.url }}" class="pes-spec-button pes-spec-{{ spec.type }}" target="_blank" rel="noopener noreferrer">
            <span class="pes-spec-icon">
              {% case spec.type %}
                {% when 'datasheet' %}📄
                {% when 'manual' %}📖
                {% when 'warranty' %}🛡️
                {% when 'installation' %}🔧
                {% when 'quick_start' %}⚡
                {% when 'certification' %}✅
                {% when 'brochure' %}📋
                {% else %}📄
              {% endcase %}
            </span>
            <span class="pes-spec-label">{{ spec.title }}</span>
            <span class="pes-spec-hint">{% if spec.isLocal %}Local{% else %}PDF{% endif %}</span>
          </a>
        {% endfor %}
      {% endif %}
    </div>
  </div>

  <style>
    .pes-specs-wrapper { margin: 20px 0; }
    .pes-specs-title { font-size: 16px; font-weight: 700; margin-bottom: 12px; color: #1a1a1a; }
    .pes-specs-buttons { display: flex; flex-wrap: wrap; gap: 8px; }
    .pes-spec-button {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 16px;
      border-radius: 6px;
      text-decoration: none;
      font-size: 14px;
      font-weight: 600;
      transition: all 0.2s;
      border: 1px solid #ddd;
      background: #fff;
      color: #333;
    }
    .pes-spec-button:hover { background: #f5f5f5; border-color: #bbb; }
    .pes-spec-icon { font-size: 18px; line-height: 1; }
    .pes-spec-label { flex: 1; }
    .pes-spec-hint { font-size: 11px; color: #888; font-weight: 400; text-transform: uppercase; }
    .pes-spec-datasheet { border-color: #2196f3; color: #1565c0; }
    .pes-spec-datasheet:hover { background: #e3f2fd; }
    .pes-spec-manual { border-color: #ff9800; color: #e65100; }
    .pes-spec-manual:hover { background: #fff3e0; }
    .pes-spec-warranty { border-color: #4caf50; color: #2e7d32; }
    .pes-spec-warranty:hover { background: #e8f5e9; }

    @media (max-width: 640px) {
      .pes-specs-buttons { flex-direction: column; }
      .pes-spec-button { width: 100%; justify-content: flex-start; }
    }
  </style>
{% endif %}
