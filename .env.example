# PES Engine — Environment Configuration
# Production / Development / Test settings
# Copy this file to .env and fill in your values

# ============================================
# APP CONFIGURATION
# ============================================
NODE_ENV=production
PORT=3000
AIRGAP_MODE=true
APP_VERSION=1.0.0

# ============================================
# SHOPIFY CREDENTIALS
# ============================================
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_APP_URL=https://your-app-url.ngrok.io
SHOPIFY_ADMIN_API_ACCESS_TOKEN=your_admin_api_token
SHOPIFY_STORE_DOMAIN=portlandiaelectricsupply.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_token
SHOPIFY_API_VERSION=2024-04

# ============================================
# DATABASE
# ============================================
DATABASE_URL=file:./data/pes-engine.db
DATABASE_PROVIDER=sqlite

# PostgreSQL (enterprise mode)
# DATABASE_URL=postgresql://user:password@localhost:5432/pes_engine?schema=public
# DATABASE_PROVIDER=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pes_engine
DB_USER=pes
DB_PASSWORD=your_db_password
DB_SSL=false

# Redis (enterprise mode)
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET=your_jwt_secret_change_in_production
SESSION_SECRET=your_session_secret_change_in_production
BCRYPT_ROUNDS=12

# Rate limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGINS=http://localhost:3000,https://admin.shopify.com

# ============================================
# ENTERPRISE / SSO
# ============================================
SSO_PROVIDER=none
SAML_ENTRY_POINT=
SAML_ISSUER=
SAML_CERT=
SAML_PRIVATE_KEY=
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
LDAP_URL=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_SEARCH_BASE=

# ============================================
# FILE STORAGE
# ============================================
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE=52428800
ALLOWED_UPLOAD_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel,text/csv

# ============================================
# EXTERNAL APIs (Disabled in Airgap Mode)
# ============================================
COMPETITOR_SCRAPING_ENABLED=false
COMPETITOR_SCRAPING_DELAY=1000
MANUFACTURER_SPEC_FETCH_ENABLED=false
EMAIL_SERVICE_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@portlandiaelectric.supply
SMTP_SECURE=false
ANALYTICS_ENABLED=false
ANALYTICS_PROVIDER=none
LLM_GENERATION_ENABLED=false
LLM_PROVIDER=none
LLM_API_KEY=
CLOUD_STORAGE_ENABLED=false
CLOUD_STORAGE_PROVIDER=none

# ============================================
# CRON / SCHEDULED JOBS
# ============================================
CRON_ENABLED=true
VENDOR_SYNC_SCHEDULE=0 2 * * 1
EOL_SCAN_SCHEDULE=0 3 * * *
HEALTH_SCAN_SCHEDULE=0 4 * * *
COMPETITOR_MONITOR_SCHEDULE=0 5 * * 1
REPORT_SCHEDULE=0 6 1 * *

# ============================================
# VENDOR-SPECIFIC CREDENTIALS
# ============================================
GENERAC_WHS_USERNAME=
GENERAC_WHS_PASSWORD=
GENERAC_WHS_URL=https://www.generac.com/whs-gold
CUMMINS_DEALER_USERNAME=
CUMMINS_DEALER_PASSWORD=
CUMMINS_DEALER_URL=https://www.cummins.com/dealer-portal
EG4_DEALER_USERNAME=
EG4_DEALER_PASSWORD=
EG4_DEALER_URL=https://www.eg4electronics.com/dealer
ENPHASE_PARTNER_USERNAME=
ENPHASE_PARTNER_PASSWORD=
ENPHASE_PARTNER_URL=https://www.enphase.com/partner-portal
SOLAREDGE_MONITOR_USERNAME=
SOLAREDGE_MONITOR_PASSWORD=
SOLAREDGE_MONITOR_URL=https://www.solaredge.com/monitoring

# ============================================
# PRICING & MAP RULES
# ============================================
DEFAULT_PRICING_STRATEGY=map
COST_PLUS_MARGIN=15
MAP_VIOLATION_THRESHOLD=0.01
PRICE_BATCH_SIZE=100

# ============================================
# THEME EXTENSIONS
# ============================================
EXTENSION_DEV_STORE=portlandiaelectricsupply.myshopify.com
EXTENSION_THEME_ID=

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FILE=./data/logs/pes-engine.log
LOG_MAX_SIZE=10
LOG_MAX_FILES=5

# ============================================
# BACKUP & RECOVERY (Enterprise)
# ============================================
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 0 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=./data/backups

# ============================================
# DEVELOPMENT ONLY
# ============================================
REMIX_DEV_SERVER_WS_PORT=8002
NGROK_AUTHTOKEN=
HOT_RELOAD=true
DEBUG=false

# ============================================
# DOCKER / PRODUCTION
# ============================================
DOCKER_NETWORK=pes-engine-network
DOCKER_CONTAINER_NAME=pes-engine
DOCKER_RESTART=unless-stopped
DOCKER_HEALTH_INTERVAL=30
DOCKER_HEALTH_TIMEOUT=10
