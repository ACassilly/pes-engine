{
  "name": "pes-engine",
  "version": "1.0.0",
  "description": "PES Engine — Unified Shopify app for Portlandia Electric Supply (PES). Vendor catalog sync, EOL detection, pricing engine, catalog health monitor, manufacturer spec linker, and competitor intelligence.",
  "author": "Portlandia Electric Supply <webmaster@portlandiaelectric.supply>",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "remix build",
    "dev": "shopify app dev",
    "config:link": "shopify app config link",
    "config:use": "shopify app config use",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "env": "shopify app env",
    "lint": "eslint --no-error-on-unmatched-pattern --ext .js,.ts,.jsx,.tsx app/",
    "lint:fix": "eslint --no-error-on-unmatched-pattern --ext .js,.ts,.jsx,.tsx app/ --fix",
    "format": "prettier --write --list-different '**/*.{js,jsx,ts,tsx,json,md,yml}'",
    "format:check": "prettier --check '**/*.{js,jsx,ts,tsx,json,md,yml}'",
    "setup": "bash scripts/setup.sh",
    "seed": "tsx prisma/seed.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker build -t pes-engine .",
    "docker:run": "docker run -p 3000:3000 --env-file .env pes-engine",
    "docker:compose": "docker compose up --build",
    "docker:compose:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d",
    "docker:compose:enterprise": "docker compose --profile enterprise up -d",
    "extension:deploy": "shopify app deploy --include extensions",
    "extension:dev": "shopify app dev --include extensions"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "@remix-run/node": "^2.5.0",
    "@remix-run/react": "^2.5.0",
    "@remix-run/serve": "^2.5.0",
    "@shopify/app-bridge": "^3.7.0",
    "@shopify/polaris": "^12.0.0",
    "@shopify/polaris-icons": "^8.0.0",
    "@shopify/shopify-api": "^9.0.0",
    "@shopify/shopify-app-remix": "^2.5.0",
    "@shopify/shopify-app-session-storage-prisma": "^5.0.0",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-table": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cross-env": "^7.0.3",
    "date-fns": "^3.0.0",
    "express": "^4.18.2",
    "isbot": "^4.0.0",
    "node-cron": "^3.0.3",
    "pdf-lib": "^1.17.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.50.0",
    "recharts": "^2.10.0",
    "zod": "^3.22.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.5.0",
    "@shopify/app": "^3.54.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.0",
    "prisma": "^5.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "workspaces": [
    "extensions/*"
  ],
  "trustedDependencies": [
    "@shopify/shopify-api"
  ]
}
